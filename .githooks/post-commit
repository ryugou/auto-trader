#!/bin/sh
# .githooks/post-commit
#
# commit 後にバックグラウンドで cargo sweep を走らせ、7 日以上アクセスの無い
# build artifact を回収する。`target/` 肥大化を抑える狙い。
#
# 出力は捨て、prompt を妨げないよう即 detach。cargo-sweep が未導入だと
# silently no-op (`>/dev/null 2>&1` で stderr 捨て)。意図的: hook の有無で
# commit を止めない。

cargo sweep --time 7 >/dev/null 2>&1 &
