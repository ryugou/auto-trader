#!/bin/sh
# .githooks/pre-push
#
# 強制ルール: main / master への直 push はドキュメントのみの場合に限り許可。
# それ以外は branch + PR を要求する (memory: main 直接 push 絶対禁止)。
#
# テスト実行 (scripts/test-all.sh) はこの hook では強制しない。実装ワークフロー
# 側で commit 前に通すのが本筋であり、push 時点で再実行するのは事後対応。
# エージェント層 (Claude Code PreToolUse hook) で commit 時点に test 強制する。

set -e

is_doc() {
  case "$1" in
    *.md|*.txt|docs/*|CLAUDE.md|TESTING.md) return 0 ;;
    *) return 1 ;;
  esac
}

while read -r local_ref local_oid remote_ref remote_oid; do
  zero='0000000000000000000000000000000000000000'
  if [ "$local_oid" = "$zero" ]; then
    continue  # ref deletion
  fi

  # range 必ず "<base>..<local_oid>" 形にする。新規 branch で merge-base が
  # 見つからない場合は git の empty-tree SHA を base にする (= local_oid 全ファイル
  # を変更扱い)。単純な "$local_oid" 単体だと git diff が working tree 比較に
  # 化けて意図しないファイルを拾うので避ける。
  EMPTY_TREE='4b825dc642cb6eb9a060e54bf8d69288fbee4904'
  # デフォルトブランチを動的に検出 (main / master / その他に対応)
  default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
  default_branch="${default_branch:-main}"
  if [ "$remote_oid" = "$zero" ]; then
    base=$(git merge-base "$local_oid" "origin/$default_branch" 2>/dev/null || echo "$EMPTY_TREE")
  else
    base="$remote_oid"
  fi
  range="$base..$local_oid"

  files=$(git diff --name-only "$range" 2>/dev/null || echo "")

  has_non_doc=0
  for f in $files; do
    if ! is_doc "$f"; then
      has_non_doc=1
      break
    fi
  done

  branch=${local_ref#refs/heads/}
  if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
    if [ "$has_non_doc" = "1" ]; then
      echo "" >&2
      echo "ERROR: Direct push to $branch is blocked (non-doc changes present)." >&2
      echo "Create a feature branch and submit a PR." >&2
      echo "" >&2
      exit 1
    fi
  fi
done

exit 0
